# LLM API key (required) — value can be any OpenAI-protocol compatible
# provider's key (Gemini via deeprouter / OpenRouter / direct OpenAI /
# DeepSeek / etc). The variable name is GEMINI_API_KEY for legacy
# reasons, the provider is decoupled by GEMINI_BASE_URL below.
GEMINI_API_KEY=sk-xxxxxxxxx

# Demo user_id. Default UUID is auto-seeded by docker-compose's backend
# command; override only if you want a different demo user.
APP_USER_ID=00000000-0000-0000-0000-000000000001

# Database URL.
# - In docker-compose: leave UNSET; compose injects the postgres service
#   name automatically.
# - In host-mode dev: leave UNSET to use config.yaml's localhost default,
#   OR set this to override (e.g. point at a remote staging DB).
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docqa

# Optional LLM overrides (defaults baked into config.yaml + compose).
# These let you point the same OpenAI-compatible client at a different
# gateway / model without touching code.
# GEMINI_MODEL_ID=gemini-2.5-flash
# GEMINI_BASE_URL=https://deeprouter.top/v1

# Optional: override retrieval threshold (default 0.35)
# MIN_SIMILARITY=0.35

# Auth — starlette SessionMiddleware signing key. PROD MUST set a strong
# random value (e.g. `python -c 'import secrets; print(secrets.token_hex(32))'`).
# Dev fallback is allowed but logs a loud warning at startup.
# SESSION_SECRET=replace-with-32-random-bytes

# When true (default), unauthenticated requests fall back to a seeded
# demo user so the localhost demo flow keeps working without
# registering. PROD MUST set this to false to require real login.
# ALLOW_DEMO_LOGIN=true
