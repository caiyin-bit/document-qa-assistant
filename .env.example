# Moonshot / 硅基流动 API key (required)
MOONSHOT_API_KEY=sk-xxxxxxxxx

# Demo user_id. Default UUID is auto-seeded by docker-compose's
# backend command; override only if you want a different demo user.
APP_USER_ID=00000000-0000-0000-0000-000000000001

# Database URL.
# - In docker-compose: leave UNSET; compose injects the postgres service
#   name automatically.
# - In host-mode dev: leave UNSET to use config.yaml's localhost default,
#   OR set this to override (e.g. point at a remote staging DB).
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docqa

# Optional Kimi overrides (defaults baked into config.yaml + compose)
# MOONSHOT_MODEL_ID=Pro/moonshotai/Kimi-K2.6
# MOONSHOT_BASE_URL=https://api.siliconflow.cn/v1

# Optional: override retrieval threshold (default 0.35)
# MIN_SIMILARITY=0.35
